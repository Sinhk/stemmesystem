@page "/nytt-arrangement"
@using Models
@using Stemmesystem.Web.Data
@inject ArrangementService ArrangementService
@inject NavigationManager Navigation

<h3>Nytt arrangement</h3>
<EditForm Model="@arrangement" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <CustomValidator @ref="customValidator" />
    <ValidationSummary />
    <div class="form-group">
        <label>Navn<InputText class="form-control" placeholder="Navn" @bind-Value="arrangement.Navn"/></label>
    </div>
    <div class="form-group">
        <label>Beskrivelse<InputText class="form-control" placeholder="Beskrivelse" @bind-Value="arrangement.Beskrivelse"/></label>
    </div>
    <div class="form-row">
        <div class="form-group col-md.6">
            <label>Startdato<InputDate class="form-control" @bind-Value="arrangement.Startdato"/></label>
        </div>
        <div class="form-group col-md-6">
            <label>Sluttdato<InputDate class="form-control" @bind-Value="arrangement.Sluttdato"/></label>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Lagre</button>
</EditForm>

@code {
    private CustomValidator? customValidator;

    private ArrangementModel arrangement = new ArrangementModel();

    private async Task HandleValidSubmit(){
        customValidator?.ClearErrors();
        var errors = new Dictionary<string, List<string>>();
        if(!await ArrangementService.IsNameAvailable(arrangement.Navn!))
           errors.Add(nameof(arrangement.Navn), new List<string>{"Navn er allerede brukt"});
        if (errors.Count() > 0)
        {
           customValidator?.DisplayErrors(errors);
           return;
        }
        await ArrangementService.NyttArrangement(arrangement);
        Navigation.NavigateTo("");
    }

}
