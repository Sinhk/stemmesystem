@page "/{navn}"

@using Microsoft.AspNetCore.SignalR.Client
@using Stemmesystem.Web.Data
@using Stemmesystem.Data
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage

@inject ArrangementService ArrangementService
@inject IDelegatService DelegatService
@inject NavigationManager NavigationManager
@inject ProtectedSessionStorage ProtectedSessionStore

@implements IAsyncDisposable

<h2>@Navn</h2>

@if (_arrangement == null)
{
    <p><em>Loading...</em></p>
}
else
{
    @if (delegat != null)
    {
    <h3>Delegat: @delegat.Delegatnummer (@delegat.Navn)</h3>
        if(_arrangement.AktivVotering() != null){
            <AktivVotering Votering=_arrangement.AktivVotering() DelegatKode=@delegat.Delegatkode/>
        }
    }
    else
    {
        <h3>Du er ikke logget inn. Du må logge inn for å kunne stemme</h3>
        <DelegatkodeInput GyldigDelegat="@(SetDelegat)"/>
    }
    <br>
    <br>
    <h4>Saker</h4>
    <table class="table">
        <thead>
            <tr>
                <th>Saknummer</th>
                <th>Tittel</th>
                <th>Beskrivelse</th>
                <th>Voteringer</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sak in _arrangement.Saker.OrderBy(s => s.Nummer))
            {
                <tr>
                    <td>@sak.Nummer</td>
                    <td>@sak.Tittel</td>
                    <td>@sak.Beskrivelse</td>
                    <table>
                        @foreach (var votering in sak.Voteringer)
                        {
                            <tr><td>@votering.Tittel</td><td>@votering.AvgitStemme.Count()/@_arrangement.Delegater.Count()</td></tr>
                        }
                    </table>
                </tr>
            }
        </tbody>
    </table>
    <h4>Delegater</h4>
    <table class="table">
        <thead>
            <tr>
                <th>Delegatnummer</th>
                <th>Navn</th>
                <th>Epost</th>
                <th>Telefon</th>
                <th>kode</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var delegat in _arrangement.Delegater.OrderBy(s => s.Delegatnummer))
            {
                <tr>
                    <td>@delegat.Delegatnummer</td>
                    <td>@delegat.Navn</td>
                    <td>@delegat.Epost</td>
                    <td>@delegat.Telefon</td>
                    <td><a href="kode/@delegat.Delegatkode">@delegat.Delegatkode</a></td>
                </tr>
            }
        </tbody>
    </table>
}
