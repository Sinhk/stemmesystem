@page "/"

@using Stemmesystem.Web.Data
@inject IDelegatService DelegatService
@inject NavigationManager Navigation

<h1>Romsdal og Nordmøre krets's stemmeside</h1>

<label>Skriv PIN her for å logge inn:</label>
<form @onsubmit="DelegatLogin">
    @if(_error != null){
        <span class="text-danger">@_error</span>
    }
  <div class="form-row align-items-center">
      <div class="col-auto">
        
        <input type="text" class="form-control form-control-lg" id="pininput" placeholder="PIN" @bind-value=_pin>
      </div>
      <div class="col-auto">
          <button type="submit" class="btn btn-primary mb-2">Logg inn</button>
      </div>
  </div>
</form>

@code {
    private string? _pin;
    private string? _error;

    [CascadingParameter]
    private DelegatStateProvider? DelegatStateProvider { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (DelegatStateProvider?.Delegatkode != null)
        {
            var delegat = await DelegatStateProvider.GetDelegat();
            if (delegat != null)
            {
                Navigation.NavigateTo($"/arrangement/{delegat.ArrangementId}");    
            }
        }
    }

    private async Task DelegatLogin(){
        _error = null;
        if (_pin == null)
        {
            _error = "Ingen PIN oppgitt";
            return;
        }
        if (_pin.Length < 4){
            _error = "PIN er minimum 4 tegn";
            return;
        }

        var delegat = await DelegatService.ValiderKode(_pin.ToUpperInvariant());
        if(delegat == null){
            _error = "Ikke en gyldig PIN";
            return;
        }
        if(DelegatStateProvider != null){
            DelegatStateProvider.Delegatkode = _pin;
            await DelegatStateProvider.SaveChangesAsync();
        }
        Navigation.NavigateTo($"/arrangement/{delegat.ArrangementId}");
    }
}
