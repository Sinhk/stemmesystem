@using Stemmesystem.Web.Data
@using Stemmesystem.Data
@inject ArrangementService ArrangementService
@inject NavigationManager Navigation

<h1>Arrangementer</h1>

@if (_arrangementer == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Navn</th>
                <th>Beskrivelse</th>
                <th>Saker</th>
                <th>Delegater</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var arrangement in _arrangementer)
            {
                <tr>
                    <td>@arrangement.Navn</td>
                    <td>@arrangement.Beskrivelse</td>
                    <td>@arrangement.Saker.Count (@arrangement.Saker.Sum(s => s.Voteringer.Count) voteringer) </td>
                    <td>@arrangement.Delegater.Count</td>
                    <td>
                        <button class="btn btn-secondary" @onclick="@(_ => Navigation.NavigateTo($"admin/arrangement/{arrangement.Id}"))">Rediger</button>
                        <button class="btn btn-primary" @onclick="@(_ => Navigation.NavigateTo($"arrangement/{arrangement.Id}"))">Gå til</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private ICollection<Arrangement>? _arrangementer;

    protected override async Task OnInitializedAsync()
    {
        _arrangementer = await ArrangementService.HentArrangementAsync();
    }

    private void NavigerTilArrangement(int id)
    {
        Navigation.NavigateTo($"arrangement/{id}");
    }
}