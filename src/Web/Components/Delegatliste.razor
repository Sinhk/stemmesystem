@using Stemmesystem.Data
@using Stemmesystem.Tools
@using Stemmesystem.Web.Data
@using Stemmesystem.Web.Models
@using Stemmesystem.Web.Services
@using System.IO

@inject IDelegatService DelegatService
@inject IPinSender PinSender
@inject NavigationManager Navigation

<div class="row" @onclick=@(_ => _expanded=!_expanded)>
    <h4>Delegater</h4>
    <span class="ml-2 mt-1 oi @(_expanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
</div>
@if (_expanded)
{
    <table class="table">
        <thead>
        <tr>
            <th @ondblclick=@(_ => _showPin=!_showPin)>Delegat</th>
            @if (_showPin)
            {
                <th>Pin</th>    
            }
            <th>Send PIN</th>
            <th>PIN sendt</th>
        </tr>
        </thead>
        @if(_delegater == null || !_delegater.Any())
        {
            <tr><td class="text-danger">Ingen delegater</td></tr>
        }
        else
        {
            <tbody>
            @foreach (var delegat in _delegater.OrderBy(s => s.Delegatnummer))
            {
                <tr>
                    <td>@delegat.Delegatnummer: @delegat.Navn</td>
                    @if (_showPin)
                    {
                        <td>@delegat.Delegatkode</td>
                    }
                    <td>
                        @if (!string.IsNullOrEmpty(delegat.Telefon))
                        {
                            <SendPinSmsComponent DelegatId="delegat.Id" OnSendt="@(()=>  SmsSendt(delegat.Id))"/>  
                        }
                        @if (!string.IsNullOrEmpty(delegat.Epost))
                        {
                            <SendPinEmailComponent DelegatId="delegat.Id" OnSendt="@(()=>  EpostSendt(delegat.Id))"/>
                        }
                    </td>
                    <td>
                        <ul class="list-unstyled">
                            @if (delegat.SendtEmail != null)
                            {
                                <li>Epost sendt @delegat.SendtEmail.Value.ToString("g")</li>
                            }
                            @if (delegat.SendtSms != null)
                            {
                                <li>SMS sendt @delegat.SendtSms.Value.ToString("g")</li>
                            }
                            @if (delegat.SendtEmail == null && delegat.SendtSms == null)
                            {
                                <li class="text-danger">Nei</li>
                            }
                        </ul>
                        
                    </td>
                </tr>
            }
            </tbody>
        }
    </table>
}
@code {

    [Parameter]
    public int ArrangementId { get; set; }

    private bool _expanded;
    private bool _showPin;

    private ICollection<Delegat> _delegater = null!;


    protected override async Task OnInitializedAsync()
    {
        _delegater = await DelegatService.HentDelegater(ArrangementId);
    }

    private void SmsSendt(int delegatId)
    {
        var delegat = _delegater.FirstOrDefault(d => d.Id == delegatId);
        if (delegat != null)
        {
            delegat.SendtSms = DateTimeOffset.Now;
        }
    }
    private void EpostSendt(int delegatId)
    {
        var delegat = _delegater.FirstOrDefault(d => d.Id == delegatId);
        if (delegat != null)
        {
            delegat.SendtEmail = DateTimeOffset.Now;
        }
    }
}
