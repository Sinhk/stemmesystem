@inject IAdminDelegatService DelegatService
@inject IPinSender PinSender
@inject NavigationManager Navigation
@using Stemmesystem.Shared.Interfaces
@using Stemmesystem.Shared.Models

<div class="row" @onclick="@(_ => _expanded=!_expanded)">
    <h4>Delegater</h4>
    <span class="ml-2 mt-1 oi @(_expanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
</div>
@if (_expanded)
{
    <table class="table table-hover">
        <thead>
        <tr>
            <th @ondblclick=@(_ => _showPin=!_showPin)>Delegat</th>
            @if (_showPin)
            {
                <th>Pin</th>    
            }
            <th>Til stede</th>
            @* <th>Aktiv</th> *@
            <th>Send PIN</th>
            <th>PIN sendt</th>
        </tr>
        </thead>
        @if(!_delegater.Any())
        {
            <tr><td class="text-danger">Ingen delegater</td></tr>
        }
        else
        {
            <tbody>
            @foreach (var delegat in _delegater.Values.OrderBy(s => s.Delegatnummer))
            {
                <tr>
                    <td>@delegat.Delegatnummer: @delegat.Navn</td>
                    @if (_showPin)
                    {
                        <td>@delegat.Delegatkode</td>
                    }
                    <td>
                        <ToggleInput Value="delegat.TilStede" ValueChanged="@(b => SetTilstede(delegat.Id, b))"/>
                    </td>
                    <td>
                        
                        @if (!string.IsNullOrEmpty(delegat.Telefon))
                        {
                            <SendPinSmsComponent DelegatId="delegat.Id" OnSendt="@(() => SmsSendt(delegat.Id))"/>
                        }
                        @if (!string.IsNullOrEmpty(delegat.Epost))
                        {
                            <SendPinEmailComponent DelegatId="delegat.Id" OnSendt="@(() => EpostSendt(delegat.Id))"/>
                        }
                    </td>
                    <td>
                        <ul class="list-unstyled">
                            @if (delegat.SendtEmail != null)
                            {
                                <li>Epost sendt @delegat.SendtEmail.Value.ToString("g")</li>
                            }
                            @if (delegat.SendtSms != null)
                            {
                                <li>SMS sendt @delegat.SendtSms.Value.ToString("g")</li>
                            }
                            @if (delegat.SendtEmail == null && delegat.SendtSms == null)
                            {
                                <li class="text-danger">Nei</li>
                            }
                        </ul>
                        
                    </td>
                </tr>
            }
            </tbody>
        }
    </table>
    <div class="row">
        <div class="col">
            <button class="btn btn-primary" @onclick="() => SetTilstede(true)">Set alle til stede</button>
            <button class="btn btn-secondary" @onclick="() => SetTilstede(false)">Set ingen til stede</button>
        </div>
    </div>
}
@code {

    [Parameter]
    public int ArrangementId { get; set; }

    private bool _expanded;
    private bool _showPin;

    private Dictionary<int, AdminDelegatDto> _delegater = null!;


    protected override async Task OnInitializedAsync()
    {
        var delegater = await DelegatService.HentDelegater(new HentDelegatRequest(ArrangementId));
        _delegater = delegater.ToDictionary(d => d.Id);
    }

    private void SmsSendt(int delegatId)
    {
        var delegat = _delegater.GetValueOrDefault(delegatId);
        if (delegat != null)
        {
            delegat.SendtSms = DateTime.Now;
        }
    }
    private void EpostSendt(int delegatId)
    {
        var delegat = _delegater.GetValueOrDefault(delegatId);
        if (delegat != null)
        {
            delegat.SendtEmail = DateTime.Now;
        }
    }

    private async Task SetTilstede(int delegatId, bool tilStede)
    {
        await DelegatService.SetTilStede(new SetTilstedeRequest(delegatId, tilStede));
    }
    
    private async Task SetTilstede(bool tilStede)
    {
        await DelegatService.SetTilStedeForAll(new SetTilstedeForAllRequest(ArrangementId, tilStede));
        foreach (var delegat in _delegater.Values)
        {
            delegat.TilStede = tilStede;
        }
    }
}
