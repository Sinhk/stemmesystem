
@inject IAdminStemmeService StemmeService

@using System.Collections.Concurrent
@using Stemmesystem.Shared.Interfaces
@using Stemmesystem.Shared.Models
@using Stemmesystem.Shared
@using Stemmesystem.Client.SignalR
@using static Stemmesystem.Client.Components.Saksliste
@implements IDisposable

<div class="card">
    <div class="card-header" @onclick="@(_ => _visDetaljer = !_visDetaljer)">
        <div class="row">
            <div class="col">
                @Votering.Tittel
                <span>
                    <small>@Votering.Beskrivelse</small>
                </span>
                @if(Votering.Publisert)
                {
                    <span class="badge badge-success">Publisert</span>
                }
                else if(Votering.Lukket)
                {
                    <span class="badge badge-primary">Lukket</span>
                }
                else if(Votering.Aktiv)
                {
                <span class="badge badge-danger">Aktiv</span>
                }
            </div>
            <div class="col">
                @if (Votering.Lukket)
                {
                    <span>
                        Avgitte stemmer:@_harStemt.Count@(Votering.DelegaterTilstede is null ? "" : $"/{Votering.DelegaterTilstede}")
                    </span>
                }
                else
                {
                    <span>
                        Avgitte stemmer:@_harStemt.Count/@DelegaterTilstede
                    </span>
                }
                    
            </div>

            <div class="col">
                @if (Votering.Aktiv)
                {
                    <div class="text-right">
                        <button class="btn btn-danger" @onclick:stopPropagation @onclick="@(async () => await StoppVotering(ArrangementId, Votering.Id))">Stopp</button>
                    </div>
                }
                else if (!Votering.Lukket)
                {
                    <div class="text-right">
                        <button class="btn btn-success" @onclick:stopPropagation @onclick="@(async () => await StartVotering(ArrangementId, Votering.Id))">Start</button>

                        @if (Votering.SluttTid != null)
                        {
                            <button class="btn btn-primary" @onclick:stopPropagation @onclick="@(async () => await LukkVotering(ArrangementId, Votering.Id))">Lukk</button>
                        }
                    </div>
                }
                else if (!Votering.Publisert)
                {
                    <div class="text-right">
                        <button class="btn btn-primary" @onclick:stopPropagation @onclick="@(async () => await PubliserVotering(ArrangementId, Votering.Id))">Publiser</button>
                    </div>
                }
                @if(Votering.Lukket)
                {
                    <div class="text-right">
                        <button class="btn btn-primary" @onclick:stopPropagation @onclick="@(async () => await NyRunde(ArrangementId, Votering.Id))">Ny Runde</button>
                    </div>
                }
            </div>
        </div>
        <span class="ml-2 mt-1 oi float-right @(_visDetaljer ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
    </div>
    @if (Votering.Lukket)
    {
    <div class="collapse @(_visDetaljer ? "show" : "")" id="collapseOne">
        <div class="card-body">
            @{
                var blankeStemmer = Votering.Stemmer.Values.Count(s => s.ValgId == Konstanter.BlankStemme);
                var avgitteStemmer = _harStemt.Count;
                var tellendeStemmer = avgitteStemmer - blankeStemmer;
                <b>Tellende stemmer: @tellendeStemmer</b>
                <ul>
                    @foreach (var valg in Votering.Valg.OrderBy(v => v.SortId))
                    {
                        var stemmer = Votering.Stemmer.Values.Count(s => s.ValgId == valg.Id);
                        <li>@valg.Navn: @stemmer (@(100*stemmer/tellendeStemmer)%)</li>
                    }
                </ul>
                <p>Blanke stemmer: @blankeStemmer</p>
            }
        </div>
    </div>
    }
</div>

@if (_nyRunde != null)
{
    <VoteringFormInline Votering="_nyRunde" OnSuccess="@(() => _nyRunde = null)"/>
}

@code {

    [Parameter]
    public DashboardVoteringModel Votering { get; set; } = null!;
    
    [Parameter]
    public IAdminNotifierService Notifier { get; set; } = null!;

    [Parameter]
    public int ArrangementId { get; set; }
    
    [CascadingParameter(Name = "DelegaterTilestede")]
    public int DelegaterTilstede { get; set; }
    
    private VoteringInputModel? _nyRunde;
    private bool _visDetaljer;
    private ConcurrentDictionary<int, bool> _harStemt = new();
    private IDisposable? _subscription;


    protected override void OnInitialized()
    {
        _subscription = Notifier.OnHarStemt(OnHarStemt);

        foreach (var delegatId in Votering.AvgitStemme)
        {
            _harStemt[delegatId] = true;    
        }
    }

    private void OnHarStemt(HarStemtEvent e)
    {
        if (e.VoteringId != Votering.Id) return;
        InvokeAsync(() =>
        {
            _harStemt[e.DelegatId] = true;
            StateHasChanged();
        });
    }

    private async Task StartVotering(int arrangementId, int voteringId)
    {
        await StemmeService.StartVotering(new AdminStemmeRequest(arrangementId, voteringId));
    }

    private async Task StoppVotering(int arrangementId, int voteringId)
    {
        await StemmeService.StoppVotering(new AdminStemmeRequest(arrangementId, voteringId));
    }

    private async Task LukkVotering(int arrangementId, int voteringId)
    {
        await StemmeService.LukkVotering(new AdminStemmeRequest(arrangementId, voteringId));
    }

    private async Task PubliserVotering(int arrangementId, int voteringId)
    {
        await StemmeService.PubliserVotering(new AdminStemmeRequest(arrangementId, voteringId));
    }


    private async Task NyRunde(int arrangementId, int voteringId)
    {
        _nyRunde = await StemmeService.KopierVotering(new AdminStemmeRequest(arrangementId, voteringId));
        var num = 2;
        if (_nyRunde.Tittel.Contains(". runde", StringComparison.OrdinalIgnoreCase))
        {
            if(int.TryParse(_nyRunde.Tittel.Split('.',StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)[0],out num))
            {
                num++;
                _nyRunde.Tittel = num + _nyRunde.Tittel[1..];
            }
        }
        else
        {
            var split = _nyRunde.Tittel.Split("Runde",StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
            if (split.Length > 1)
            {
                var numStr = split[1];
                int.TryParse(numStr.Trim(), out num);
                num++;
            }
            _nyRunde = _nyRunde with{ Tittel = $"{split[0].TrimEnd('-', ' ')} - Runde {num}"};
        }

        StateHasChanged();
    }

    public void Dispose()
    {
        _subscription?.Dispose();
    }

}