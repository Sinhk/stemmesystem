
@inject IAdminVoteService StemmeService

@using System.Collections.Concurrent
@using Stemmesystem.Shared.Interfaces
@using Stemmesystem.Shared.Models
@using Stemmesystem.Shared
@using Stemmesystem.Client.SignalR
@using static Stemmesystem.Client.Components.Saksliste
@implements IDisposable

<div class="card">
    <div class="card-header" @onclick="@(_ => _visDetaljer = !_visDetaljer)">
        <div class="row">
            <div class="col">
                @Votering.Title
                <span>
                    <small>@Votering.Description</small>
                </span>
                @if(Votering.Published)
                {
                    <span class="badge badge-success">Publisert</span>
                }
                else if(Votering.Locked)
                {
                    <span class="badge badge-primary">Lukket</span>
                }
                else if(Votering.Active)
                {
                <span class="badge badge-danger">Aktiv</span>
                }
            </div>
            <div class="col">
                @if (Votering.Locked)
                {
                    <span>Avgitte stemmer:@_harStemt.Count@(Votering.DelegatesPresent is null ? "" : $"/{Votering.DelegatesPresent}")</span>
                }
                else
                {
                    <span>
                        Avgitte stemmer:@_harStemt.Count/@DelegaterTilstede
                    </span>
                }
                    
            </div>

            <div class="col">
                @if (Votering.Active)
                {
                    <div class="text-right">
                        <button class="btn btn-danger" @onclick:stopPropagation @onclick="@(async () => await StoppVotering(ArrangementId, Votering.Id))">Stopp</button>
                    </div>
                }
                else if (!Votering.Locked)
                {
                    <div class="text-right">
                        <button class="btn btn-success" @onclick:stopPropagation @onclick="@(async () => await StartVotering(ArrangementId, Votering.Id))">Start</button>

                        @if (Votering.EndTime != null)
                        {
                            <button class="btn btn-primary" @onclick:stopPropagation @onclick="@(async () => await LukkVotering(ArrangementId, Votering.Id))">Lukk</button>
                        }
                    </div>
                }
                else if (!Votering.Published)
                {
                    <div class="text-right">
                        <button class="btn btn-primary" @onclick:stopPropagation @onclick="@(async () => await PubliserVotering(ArrangementId, Votering.Id))">Publiser</button>
                    </div>
                }
                @if(Votering.Locked)
                {
                    <div class="text-right">
                        <button class="btn btn-primary" @onclick:stopPropagation @onclick="@(async () => await NyRunde(ArrangementId, Votering.Id))">Ny Runde</button>
                    </div>
                }
            </div>
        </div>
        <span class="ml-2 mt-1 oi float-right @(_visDetaljer ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
    </div>
    <div class="collapse @(_visDetaljer ? "show" : "")" id="collapseOne">
        <div class="card-body">
            @if (Votering.Locked)
            {
                <span>Kan velge: <b>@Votering.MaxChoices</b></span><br/>

                var blankeStemmer = Votering.Votes.Values.Count(s => s.ChoiceId == Konstanter.BlankStemme);
                var avgitteStemmer = _harStemt.Count;
                var tellendeStemmer = avgitteStemmer - blankeStemmer;

                @if (tellendeStemmer == 0)
                {
                    <tr><td class="text-danger">Ingen tellende stemmer</td></tr>
                }
                else
                {
                    <span>Tellende stemmer: <b>@tellendeStemmer</b></span>
                    <br/>
                    <span>Stemmer totalt: <b>@Votering.Votes.Count</b></span>
                    @if (Votering.MaxChoices > 1)
                    {
                        <br/><i>ved flervalg vil stemmer totalt være høyere enn tellende</i>
                    }
                    <ul>
                        @foreach (var valg in Votering.Choices.OrderBy(v => v.SortId))
                        {
                            var stemmer = Votering.Votes.Values.Count(s => s.ChoiceId == valg.Id);
                            <li>@valg.Name: @stemmer (@(Math.Round(100m * stemmer / tellendeStemmer, 2))%)</li>
                        }
                    </ul>
                    <p>Blanke stemmer: @blankeStemmer</p>
                }

                if (Votering.MaxChoices == 1 && avgitteStemmer != Votering.Votes.Count)
                {
                    <ul>
                        @foreach (var d in Votering.Votes.Values.GroupBy(x => x.DelegateId))
                        {
                            <li>Stemmer fra id @d.Key: @d.Count()</li>
                        }
                    </ul>
                }
            }
        </div>
    </div>
</div>

@if (_nyRunde != null)
{
    <VoteringFormInline Votering="_nyRunde" OnSuccess="@(() => _nyRunde = null)"/>
}

@code {

    [Parameter]
    public DashboardVoteringModel Votering { get; set; } = null!;
    
    [Parameter]
    public IAdminNotifierService Notifier { get; set; } = null!;

    [Parameter]
    public int ArrangementId { get; set; }
    
    [CascadingParameter(Name = "DelegaterTilestede")]
    public int DelegaterTilstede { get; set; }
    
    private BallotInputModel? _nyRunde;
    private bool _visDetaljer;
    private ConcurrentDictionary<int, bool> _harStemt = new();
    private IDisposable? _subscription;


    protected override void OnInitialized()
    {
        _subscription = Notifier.OnVoted(OnHarStemt);

        foreach (var delegatId in Votering.VotedDelegates)
        {
            _harStemt[delegatId] = true;    
        }
    }

    private void OnHarStemt(VotedEvent e)
    {
        if (e.BallotId != Votering.Id) return;
        InvokeAsync(() =>
        {
            _harStemt[e.DelegateId] = true;
            StateHasChanged();
        });
    }

    private async Task StartVotering(int arrangementId, int voteringId)
    {
        await StemmeService.StartBallot(new AdminBallotRequest(arrangementId, voteringId));
    }

    private async Task StoppVotering(int arrangementId, int voteringId)
    {
        await StemmeService.StopBallot(new AdminBallotRequest(arrangementId, voteringId));
    }

    private async Task LukkVotering(int arrangementId, int voteringId)
    {
        await StemmeService.LockBallot(new AdminBallotRequest(arrangementId, voteringId));
    }

    private async Task PubliserVotering(int arrangementId, int voteringId)
    {
        await StemmeService.PublishBallot(new AdminBallotRequest(arrangementId, voteringId));
    }


    private async Task NyRunde(int arrangementId, int voteringId)
    {
        _nyRunde = await StemmeService.CopyBallot(new AdminBallotRequest(arrangementId, voteringId));
        var num = 2;
        if (_nyRunde.Title.Contains(". runde", StringComparison.OrdinalIgnoreCase))
        {
            if(int.TryParse(_nyRunde.Title.Split('.',StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)[0],out num))
            {
                num++;
                _nyRunde.Title = num + _nyRunde.Title[1..];
            }
        }
        else
        {
            var split = _nyRunde.Title.Split("Runde",StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
            if (split.Length > 1)
            {
                var numStr = split[1];
                int.TryParse(numStr.Trim(), out num);
                num++;
            }
            _nyRunde = _nyRunde with{ Tittel = $"{split[0].TrimEnd('-', ' ')} - Runde {num}"};
        }

        StateHasChanged();
    }

    public void Dispose()
    {
        _subscription?.Dispose();
    }

}