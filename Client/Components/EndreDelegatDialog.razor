@using Microsoft.AspNetCore.Components
@using Stemmesystem.Shared.Models
<div data-show="true" class="modal" tabindex="-1" role="dialog" id="delegatModal">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Modal title</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <input @bind=Delegat.Navn/>
        <input @bind=Delegat.Epost/>
        <input @bind=Delegat.Telefon/>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary">Lagre</button>
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Lukk</button>
      </div>
    </div>
  </div>
</div>

@code {
  [Parameter]
  public DelegatDto Delegat { get; set; } = null!;
}
