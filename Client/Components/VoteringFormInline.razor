@using Microsoft.AspNetCore.Components
@using Stemmesystem.Shared.Interfaces
@using Stemmesystem.Shared.Models
@using Stemmesystem.Web.Components
@using AutoMapper
@inject ICaseService _sakService
@inject IMapper _mapper


@if (Votering.Startet)
{
    <div class="card">
        <div class="card-header">
            @Votering.Title
        </div>
        <div class="card-body">
            <em>Votering har startet og kan ikke endres</em>
        </div>
    </div>
}
else
{
    <EditForm class="mb-2" Model="@Votering" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />
        <CustomValidator @ref="_customValidator" />
        <ValidationSummary />
        <div class="card">
            <div class="card-header">
                <div class="form-row">
                    <div class="col-6">
                        <InputText class="form-control" placeholder="Tittel" @bind-Value="Votering.Title"/>
                    </div>
                    <div class="col-2">
                        <InputNumber class="form-control" placeholder="Kan velge" @bind-Value="Votering.MaxChoices"/>
                    </div>
                    <div class="form-group">
                        <div class="form-check col-3 mt-2">
                            <InputCheckbox class="form-check-input" placeholder="Hemmelig" @bind-Value="Votering.Secret" id="hemmeligCheck"/>
                            <label class="form-check-label" for="hemmeligCheck">Hemmelig</label>
                        </div>
                    </div>
                    <div class="col-10">
                        <InputText class="form-control" placeholder="Beskrivelse" @bind-Value="Votering.Description"/>
                    </div>
                    <button type="submit" class="btn btn-primary">Lagre</button>
                </div>
            </div>
            <div class="card-body">
                <h6>Valg</h6>
                @foreach (var valg in Votering.Choices.OrderBy(v => v.SortId))
                {
                    <ValgInline Valg="@valg" OnTaVekkValg="@TaVekkValg"></ValgInline>
                }
                <button type="button" class="btn btn-success btn-sm mt-1" @onclick=LeggTilValg>Legg til valg</button>
            </div>
        </div>
    </EditForm>
}

@code {

    [Parameter]
    public BallotInputModel Votering { get; set; } = null!;

    [Parameter]
    public EventCallback OnSuccess { get; set; }

    private CustomValidator? _customValidator;
    
    private async Task HandleValidSubmit(){
        _customValidator?.ClearErrors();

        Votering.Choices.RemoveAll(v => string.IsNullOrEmpty(v.Name));
        if (Votering.Id.GetValueOrDefault() != default)
        {
            var (votering, errors) = await _sakService.UpdateBallot(Votering);

            if (errors?.Count > 0)
            {
                _customValidator?.DisplayErrors(errors);
                return;
            }
            if (votering != null)
            {
                _mapper.Map(votering, Votering);  
                await OnSuccess.InvokeAsync();    
            }
        }
        else
        {
            var (votering, errors) = await _sakService.CreateBallot(Votering);
            
            if (errors?.Count > 0)
            {
                _customValidator?.DisplayErrors(errors);
                return;
            }
            
            if(votering != null)
            {
                _mapper.Map(votering, Votering);
                await OnSuccess.InvokeAsync();    
            }
        }
    }

    private void LeggTilValg()
    {
        Votering.Choices.Add(new ChoiceDto {Id = Guid.NewGuid(),SortId = Votering.Choices.Count});
    }

    private void TaVekkValg(Guid valgId)
    {
        Votering.Choices.RemoveAll(v => v.Id == valgId);
    }
}