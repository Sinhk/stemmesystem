@using Stemmesystem.Shared.Interfaces
@inject IMinSpeidingOptionsRepository Repository
@inject HttpClient HttpClient
@inject ILogger<MinSpeidingImport> Logger

@if (_minSpeidingOptions == null)
{
    <p>
        <em>Laster...</em>
    </p>
}
else
{
    <EditForm Model="@_minSpeidingOptions" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator/>
        <ValidationSummary/>
        <div class="form-group row">
            <label for="arr-id" class="col-3 col-lg-2 col-form-label">Arrangement ID</label>
            <div class="col-9 col-lg-3">
                <InputNumber id="arr-id" class="form-control" placeholder="Arrangement ID" @bind-Value="_minSpeidingOptions.Id"/>
            </div>
        </div>
        <div class="form-group row">
            <label for="api-key" class="col-3 col-lg-2 col-form-label">Participants API-nøkkel</label>
            <div class="col-9 col-lg-3"> 
                <InputText id="api-key" type="password" class="form-control" placeholder="API-nøkkel" @bind-Value="_minSpeidingOptions.MembersApiKey"/>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-3 col-lg-2"></div>
            <div class="col-9 col-lg-3">
                <div class="form-check">
                    <InputCheckbox id="check-in" class="form-check-input" @bind-Value="_minSpeidingOptions.ImportCheckIn"/>
                    <label class="form-check-label" for="check-in">Importer innsjekk som til stede</label>
                </div>
            </div>
        </div>
        <div class="form-group form-row">
            <label for="filter" class="col-3 col-lg-2 col-form-label">Filter</label>
            <div class="col-9 col-lg-5">
                <InputText id="filter" @bind-Value=_minSpeidingOptions.Filter type="text" class="form-control" placeholder="Filtrer deltakere" title="Bruk felt fra json resultatet"/>
                <small class="form-text text-muted">
                    filtrer på ett felt: <code>fee_name=Delegat</code>
                    <br/>filtrer på flere felt: <code>checked_in=true|org_name=Norges speiderforbund</code>
                    <br/>flere verdier på samme felt: <code>questions.19511=16002,16003</code>
                    <br/>Hent deltakere for å se hvilke felt som er tilgjengelig.
                </small>
            </div>
        </div>
        
        <div>
            <button type="submit" class="btn btn-primary">Lagre</button>
        </div>
    </EditForm>
    <br/>
    <div class="row">
        <div class="col-auto">
            <button class="btn btn-primary" @onclick=@(_ => LoadParticipants())>Hent deltakere</button>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" disabled="@(_participants is null)" @onclick="FilterParticipants">Filtrer</button>
        </div>
        <div class="col-auto">
            <button class="btn btn-success" disabled="@(_participants is null)" @onclick="Import">Importer deltakere</button>
        </div>
    </div>

    if (_participantError is not null)
    {
        <div class="alert alert-danger" role="alert">
            <p>@_participantError</p>
        </div>
    }

    if (_participants is not null)
    {
        <div class="row">
            
        </div>
        <div>
            <div class="row mt-2" @onclick=@(_ => _rawResultExpanded=!_rawResultExpanded)>
                <h4>json resultat</h4>
                <span class="ml-2 mt-1 oi @(_rawResultExpanded ? "oi-chevron-top" : "oi-chevron-bottom")"></span>
            </div>
            @if (_rawResultExpanded)
            {
                <pre>@_rawParticipants?.ToString() ?? "Ingen deltakere hentet"</pre>
            }
            @*<div>
                <label for="participantProperties">Velg en egenskap:</label>
                <select id="participantProperties" class="form-control">
                    @foreach (var property in _participantProperties)
                    {
                        <option value="@property">@property</option>
                    }
                </select>
            </div>*@
        </div>
        
        @if(_importResult is not null)
        {
            <div class="alert alert-success" role="alert">
                <p>@_importResult</p>
            </div>
        }
        <h3>Forhåndsvisning av import</h3>
        <table class="table">
            <thead>
            <tr>
                <th>Navn</th>
                <th>E-post</th>
                <th>Mobiltelefon</th>
                <th>Sjekket inn</th>
                <th>Pris</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var participant in _participants)
            {
                <tr>
                    <td>@participant.FullName</td>
                    <td>@participant.PrimaryEmail</td>
                    <td>@participant.ContactInfo.GetValueOrDefault("Mobiltelefon")</td>
                    <td>@(participant.CheckedIn == true ? "Ja" : "Nei")</td>
                    <td>@participant.FeeName</td>
                </tr>
            }
            </tbody>
        </table>
    }
}