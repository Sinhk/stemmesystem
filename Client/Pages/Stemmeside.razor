@page "/arrangement/{id:int}"

@attribute [Authorize(Roles = "Delegat")]

@inject IArrangementService ArrangementService
@inject IDelegatService DelegatService
@inject ISakService SakService
@inject NavigationManager NavigationManager

@using Stemmesystem.Shared.Interfaces
@using Microsoft.AspNetCore.Authorization
@implements IDisposable

@if (_arrangement == null)
{
    <p><em>Laster...</em></p>
}
else
{
    <h2>@_arrangement.Navn</h2>
    if (_delegat == null)
    {
        <h3>Fant ikke delegat info. Noe er galt</h3>
    }
    else
    {
        <h3>Delegat: @_delegat.Delegatnummer (@_delegat.Navn) @*<span class="oi oi-pencil" data-toggle="modal" data-target="#delegatModal"></span>*@</h3>
        @*<EndreDelegatDialog Delegat=@_delegat/>*@
        <div class="row">
            <h3>Voteringer</h3>
        </div>
        <div class="row">
            @if (_voteringer.Any())
            {
                foreach (var votering in _voteringer)
                {
                    <AktivVotering Votering=votering/>
                }
            }
            else
            {
                <p>
                    <em>Ingen aktiv votering</em>
                </p>
            }
        </div>
    }

}
