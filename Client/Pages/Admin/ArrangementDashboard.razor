@page "/admin/arrangement/{arrangementId:int}/dashboard"
@using Stemmesystem.Shared.Interfaces
@using Stemmesystem.Shared.Models
@using Microsoft.AspNetCore.Authorization
@using Stemmesystem.Client.SignalR
@using Stemmesystem.Shared
@inject IArrangementService ArrangementService
@inject IAdminNotifierService AdminNotifier
@implements IDisposable
@inherits OwningComponentBase<Stemmesystem.Client.SignalR.IDelegatNotifierService>
@attribute [Authorize]
<div class="row">
    <h3><b>@_arrangement?.Navn</b></h3>    
</div>
<div class="row">
    <div class="col">Saker: @_arrangement?.Saker.Count </div>
</div>
<div class="row">
    <div class="col">Delegater: @_arrangement?.Delegater.Count</div>
    <div class="col">Delegater til stede: @_delegaterTilstede</div>
    <div class="col">Aktive delegater: @_aktiveDelegater</div>
</div>
<CascadingValue Name="DelegaterTilestede" Value="_delegaterTilstede">
    <Saksliste ArrangementId="ArrangementId" />
    <Delegatliste ArrangementId="ArrangementId" />
</CascadingValue>

@code {
    [Parameter]
    public int ArrangementId { get; set; }
    private ArrangementDto? _arrangement;
    private int _aktiveDelegater;
    private int _delegaterTilstede;

    private IDisposable? _countSubscription;
    private IDisposable? _tilstedeSubscription;


    protected override async Task OnInitializedAsync()
    {
        var arrangement = await ArrangementService.HentArrangementAsync(new HentArrangementRequest {Id = ArrangementId});
        if(arrangement != null)
            _arrangement = arrangement;
        
        _countSubscription = Service.OnActiveCountChanged(ActiveCountChanged);
        await Service.Start();
        _aktiveDelegater = await Service.GetActiveCount(ArrangementId);
        
        _tilstedeSubscription = AdminNotifier.OnTilstedeCountChanged(TilstedeCountChanged);
        await AdminNotifier.Start();
        var tilstedeResponse = await ArrangementService.GetTilstedeCount(new TilstedeCountRequest(ArrangementId));
        _delegaterTilstede = tilstedeResponse.Count;
    }

    private void TilstedeCountChanged(TilstedeCountChangedEvent e)
    {
        if (e.ArrangementId != ArrangementId) return;
        _delegaterTilstede = e.Count;
        StateHasChanged();
    }

    private void ActiveCountChanged(ActiveCountChangedEvent e)
    {
        if (e.ArrangementId != ArrangementId) return;
        _aktiveDelegater = e.NewCount;
        StateHasChanged();
    }
    
    public void Dispose()
    {
        _countSubscription?.Dispose();
        _tilstedeSubscription?.Dispose();
    }

}