@page "/admin/arrangement/{arrangementId:int}/sak/ny-sak"
@page "/admin/arrangement/{arrangementId:int}/sak/{sakId:int}"
@using Microsoft.AspNetCore.Components
@using Stemmesystem.Shared.Interfaces
@using Stemmesystem.Shared.Models
@using Stemmesystem.Web.Components
@using Microsoft.AspNetCore.Authorization
@inject IArrangementService ArrangementService
@inject ICaseService SakService
@inject NavigationManager Navigation

@attribute [Authorize(Roles = "admin")]

@if (_sak.Id != null)
{
    <h3>Redigerer sak <b>@_sak.Title</b></h3>
}
else
{
    <h3>Ny sak</h3>    
}

<EditForm Model="@_sak" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <CustomValidator @ref="customValidator" />
    <ValidationSummary />
    <div class="form-group">
        <label>Saknummer<InputText class="form-control" placeholder="Saknummer" @bind-Value="_sak.Number"/></label>
    </div>
    <div class="form-group">
        <label>Tittel<InputText class="form-control" placeholder="Tittel" @bind-Value="_sak.Title"/></label>
    </div>
    <div class="form-group">
            <label>Beskrivelse<InputText class="form-control" placeholder="Beskrivelse" @bind-Value="_sak.Description"/></label>
        </div>

    <button type="submit" class="btn btn-primary">Lagre</button>
</EditForm>

@code {
    [Parameter]
    public int ArrangementId{get;set;}
    [Parameter]
    public int? SakId {get;set;}

    private CustomValidator? customValidator;

    private CaseInputModel _sak = new();

    protected override async Task OnInitializedAsync(){
        if(SakId != null){
            var sak = await SakService.GetCase(new CaseRequest(SakId.Value));
            if (sak != null)
                _sak = new CaseInputModel
                {
                    Beskrivelse = sak.Description,
                    Nummer = sak.Number,
                    Tittel = sak.Title,
                    Voteringer = sak.Ballots.Select(v => new BallotInputModel
                    {
                        Beskrivelse = v.Description, Hemmelig = v.Secret, KanVelge = v.MaxChoices, Tittel = v.Title, Valg = v.Choices
                    }).ToList()
                };
        }
    }

    private async Task HandleValidSubmit(){
        customValidator?.ClearErrors();
        var errors = new Dictionary<string, List<string>>();
        _sak.ArrangementId = ArrangementId;
        
        if (_sak.Id != default)
        {
            await SakService.UpdateCase(_sak);
        }
        else
        {
            if (errors.Count > 0)
            {
                customValidator?.DisplayErrors(errors);
                return;
            }
            var (sak, err) = await SakService.CreateCase(_sak);
            if(err.Any())
            {
                customValidator?.DisplayErrors(err);
                return;
            }

            if (sak != null) Navigation.NavigateTo($"/admin/arrangement/{ArrangementId}/sak/{sak.Id}");
        }
    }

}